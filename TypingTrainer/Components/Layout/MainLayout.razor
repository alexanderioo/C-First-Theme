@inherits LayoutComponentBase
@implements IDisposable
@inject SettingsRepository SettingsRepository

@* Layout — общая рамка всех страниц. @Body заменяется содержимым текущей
   страницы, а шапка и подвал не дублируются в каждом компоненте. *@
<div class="app-shell @GetThemeClass()" style="@GetApplicationStyle()">
    <header class="site-header">
        <a class="brand" href="/" aria-label="Клавиши — на главную">
            <span class="brand-mark" aria-hidden="true">
                <span></span><span></span><span></span>
            </span>
            <span>
                <strong>Клавиши</strong>
                <small>тренажёр печати</small>
            </span>
        </a>

        <nav class="main-nav" aria-label="Главное меню">
            <NavLink href="/" Match="NavLinkMatch.All">Тренировка</NavLink>
            <NavLink href="/dictionaries">Словари</NavLink>
            <NavLink href="/statistics">Статистика</NavLink>
        </nav>

        <a class="header-action" href="/settings" aria-label="Открыть настройки">
            <span aria-hidden="true">Aa</span>
            Настройки
        </a>
    </header>

    <main class="main-content">
        @Body
    </main>

    <footer class="site-footer">
        <span>Учебный проект на C# и Blazor</span>
        <span>Точность важнее спешки</span>
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Соединение с приложением потеряно.
    <a href="." class="reload">Перезагрузить</a>
    <button type="button" class="dismiss">Закрыть</button>
</div>

@code {
    private UserSettings _settings = UserSettings.Default;

    protected override async Task OnInitializedAsync()
    {
        // Подписываемся один раз при создании layout, чтобы тема менялась
        // сразу после сохранения настроек без перезагрузки страницы.
        SettingsRepository.Changed += OnSettingsChanged;
        _settings = await SettingsRepository.GetAsync();
    }

    private void OnSettingsChanged(UserSettings settings)
    {
        _settings = settings;

        // Событие может прийти не во время обычного цикла рендера Blazor.
        // InvokeAsync безопасно ставит перерисовку в очередь компонента.
        _ = InvokeAsync(StateHasChanged);
    }

    private string GetThemeClass() => _settings.Theme switch
    {
        AppTheme.Dark => "theme-dark",
        AppTheme.Contrast => "theme-contrast",
        _ => "theme-light"
    };

    private string GetApplicationStyle()
    {
        // Настройки переводятся в CSS-переменные. Страница Race использует
        // их как var(--trainer-font-size) и другие значения.
        string fontFamily = _settings.FontFamily switch
        {
            TrainerFontFamily.Sans => "\"Manrope\", system-ui, sans-serif",
            TrainerFontFamily.Serif => "Georgia, \"Times New Roman\", serif",
            _ => "\"Source Code Pro\", monospace"
        };

        double lineHeight = _settings.LineSpacing switch
        {
            LineSpacing.Compact => 1.4,
            LineSpacing.Airy => 2.0,
            _ => 1.7
        };

        return
            $"--trainer-font-size: {_settings.FontSize}px; " +
            $"--trainer-font-family: {fontFamily}; " +
            $"--trainer-line-height: {lineHeight.ToString(CultureInfo.InvariantCulture)};";
    }

    public void Dispose()
    {
        // Отписка обязательна: иначе Singleton-сервис продолжит хранить ссылку
        // на уже закрытый компонент и вызовет утечку памяти.
        SettingsRepository.Changed -= OnSettingsChanged;
    }
}
