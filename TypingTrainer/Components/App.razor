<!DOCTYPE html>
<html lang="ru">

<head>
    @* App.razor — корневой HTML-документ. Здесь подключаются общие стили,
       шрифты и служебный JavaScript, который связывает браузер с Blazor. *@
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Source+Code+Pro:wght@500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["TypingTrainer.styles.css"]" />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <ImportMap />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    @* Routes выбирает Razor-компонент по текущему адресу браузера. *@
    <Routes @rendermode="InteractiveServer" />

    @* Этот скрипт устанавливает интерактивное соединение с сервером. *@
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
