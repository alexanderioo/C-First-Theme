@page "/dictionaries/new"
@page "/dictionaries/edit/{Id:guid}"
@inject DictionaryRepository Repository
@inject NavigationManager Navigation

@* Один компонент обслуживает два URL. Если Id отсутствует — создаём словарь,
   если присутствует — загружаем существующий для редактирования. *@
<PageTitle>@(_isNew ? "Новый словарь" : "Редактирование словаря") — Клавиши</PageTitle>

<section class="editor-layout">
    <aside>
        <a class="back-link" href="/dictionaries">← Все словари</a>
        <span class="eyebrow">@(_isNew ? "Новый набор" : "Редактор")</span>
        <h1>@(_isNew ? "Создайте свой словарь" : "Настройте словарь")</h1>
        <p>
            Каждый непустой абзац станет отдельным заданием.
            Во время заезда тренажёр выберет одно из них случайно.
        </p>

        <div class="editor-tip">
            <strong>Хороший словарь</strong>
            <span>содержит хотя бы 5 текстов примерно одинаковой сложности.</span>
        </div>
    </aside>

    <div class="editor-card page-card">
        @if (_isLoading)
        {
            <p>Загружаем словарь...</p>
        }
        else if (_notFound)
        {
            <div class="form-message error">Словарь не найден.</div>
        }
        else
        {
            @* EditForm связывает поля с _model. OnValidSubmit сработает только
               после успешной проверки атрибутов [Required], [StringLength]. *@
            <EditForm Model="_model" OnValidSubmit="SaveAsync">
                <DataAnnotationsValidator />

                <div class="field">
                    <label for="dictionary-name">Название</label>
                    <InputText id="dictionary-name" @bind-Value="_model.Name" placeholder="Например, Термины по C#" />
                    <ValidationMessage For="() => _model.Name" />
                </div>

                <div class="field">
                    <label for="dictionary-description">Описание</label>
                    <InputTextArea id="dictionary-description" @bind-Value="_model.Description" rows="3"
                                   placeholder="Коротко опишите назначение словаря" />
                    <ValidationMessage For="() => _model.Description" />
                </div>

                <div class="field-grid">
                    <div class="field">
                        <label for="dictionary-language">Язык</label>
                        <InputText id="dictionary-language" @bind-Value="_model.Language" />
                        <ValidationMessage For="() => _model.Language" />
                    </div>

                    <div class="field">
                        <label for="dictionary-difficulty">Сложность</label>
                        <InputSelect id="dictionary-difficulty" @bind-Value="_model.Difficulty">
                            <option>Лёгкая</option>
                            <option>Средняя</option>
                            <option>Сложная</option>
                        </InputSelect>
                    </div>

                    <div class="field">
                        <label for="dictionary-kind">Тип</label>
                        <InputSelect id="dictionary-kind" @bind-Value="_model.Kind">
                            <option value="@DictionaryKind.Words">Слова</option>
                            <option value="@DictionaryKind.Phrases">Фразы</option>
                            <option value="@DictionaryKind.Texts">Тексты</option>
                            <option value="@DictionaryKind.Code">Код</option>
                        </InputSelect>
                    </div>
                </div>

                <div class="field">
                    <div class="field-label-row">
                        <label for="dictionary-entries">Тексты</label>
                        <span>Каждый текст с новой строки</span>
                    </div>
                    <InputTextArea id="dictionary-entries" class="entries-input"
                                   @bind-Value="_model.EntriesText" rows="12"
                                   placeholder="Первый текст для тренировки&#10;Второй текст для тренировки" />
                    <ValidationMessage For="() => _model.EntriesText" />
                </div>

                @if (!string.IsNullOrWhiteSpace(_message))
                {
                    <div class="form-message error">@_message</div>
                }

                <div class="form-actions">
                    <button class="button button-primary" type="submit" disabled="@_isSaving">
                        @(_isSaving ? "Сохраняем..." : "Сохранить словарь")
                    </button>
                    <a class="button button-secondary" href="/dictionaries">Отмена</a>

                    @if (!_isNew && !_model.IsBuiltIn)
                    {
                        <button class="delete-button" type="button" @onclick="DeleteAsync">Удалить</button>
                    }
                </div>
            </EditForm>
        }
    </div>
</section>

@code {
    [Parameter]
    // Значение приходит из сегмента {Id:guid} текущего URL.
    public Guid? Id { get; set; }

    private DictionaryEditorModel _model = new();
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _notFound;
    private string? _message;
    private bool _isNew => Id is null;

    protected override async Task OnParametersSetAsync()
    {
        // В отличие от OnInitializedAsync этот метод вызывается снова,
        // если пользователь остаётся в компоненте, но меняется параметр URL.
        _isLoading = true;
        _notFound = false;
        _message = null;

        if (Id is Guid id)
        {
            // Pattern matching одновременно проверяет null и создаёт Guid id.
            TypingDictionary? dictionary = await Repository.GetByIdAsync(id);
            if (dictionary is null)
            {
                _notFound = true;
            }
            else
            {
                _model = DictionaryEditorModel.From(dictionary);
            }
        }
        else
        {
            _model = new DictionaryEditorModel();
        }

        _isLoading = false;
    }

    private async Task SaveAsync()
    {
        _isSaving = true;
        _message = null;

        try
        {
            // Модель формы превращает многострочный textarea в список заданий.
            TypingDictionary dictionary = _model.ToDictionary();
            if (dictionary.Entries.Count == 0)
            {
                _message = "Добавьте хотя бы один непустой текст.";
                return;
            }

            await Repository.SaveAsync(dictionary);

            // После сохранения программно возвращаем пользователя к списку.
            Navigation.NavigateTo("/dictionaries");
        }
        catch (IOException exception)
        {
            _message = $"Не удалось сохранить словарь: {exception.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteAsync()
    {
        if (Id is not Guid id)
        {
            return;
        }

        // Репозиторий сам проверяет, разрешено ли удаление этого словаря.
        bool deleted = await Repository.DeleteAsync(id);
        if (deleted)
        {
            Navigation.NavigateTo("/dictionaries");
        }
        else
        {
            _message = "Встроенный словарь нельзя удалить.";
        }
    }
}
