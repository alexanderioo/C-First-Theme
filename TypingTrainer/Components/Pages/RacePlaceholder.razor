@page "/race/{DictionaryId:guid}"
@inject DictionaryRepository Repository

<PageTitle>Подготовка к заезду — Клавиши</PageTitle>

<section class="empty-state page-card">
    <span class="eyebrow">Словарь выбран</span>
    <h1>@(_dictionary?.Name ?? "Загрузка...")</h1>
    <p>Игровой экран будет добавлен в следующем этапе проекта.</p>
    <a class="button button-secondary" href="/dictionaries">Выбрать другой</a>
</section>

@code {
    [Parameter]
    public Guid DictionaryId { get; set; }

    private TypingDictionary? _dictionary;

    protected override async Task OnParametersSetAsync()
    {
        _dictionary = await Repository.GetByIdAsync(DictionaryId);
    }
}
