@page "/dictionaries"
@inject DictionaryRepository Repository

@* @inject просит контейнер зависимостей передать готовый репозиторий.
   Страница не создаёт его вручную и не работает с JSON напрямую. *@
<PageTitle>Словари — Клавиши</PageTitle>

<section class="page-heading">
    <div>
        <span class="eyebrow">Первый шаг</span>
        <h1>Выберите словарь</h1>
        <p>Каждый заезд берёт случайный текст из выбранного набора.</p>
    </div>
    <a class="button button-primary" href="/dictionaries/new">
        <span aria-hidden="true">＋</span>
        Новый словарь
    </a>
</section>

@if (_dictionaries is null)
{
    @* null здесь означает, что асинхронная загрузка ещё не завершилась. *@
    <div class="loading-card page-card">Загружаем словари...</div>
}
else
{
    <section class="dictionary-grid">
        @foreach (TypingDictionary dictionary in _dictionaries)
        {
            <article class="dictionary-card page-card">
                <div class="card-topline">
                    <span class="kind-badge">@GetKindName(dictionary.Kind)</span>
                    @if (dictionary.IsBuiltIn)
                    {
                        <span class="built-in-badge">Встроенный</span>
                    }
                </div>

                <h2>@dictionary.Name</h2>
                <p>@dictionary.Description</p>

                <div class="dictionary-meta">
                    <span>@dictionary.Language</span>
                    <span>@dictionary.Difficulty</span>
                    <span>@dictionary.Entries.Count @GetTextWord(dictionary.Entries.Count)</span>
                </div>

                <div class="dictionary-actions">
                    <a class="button button-primary" href="@($"/race/{dictionary.Id}")">Начать заезд</a>
                    <a class="edit-link" href="@($"/dictionaries/edit/{dictionary.Id}")">Редактировать</a>
                </div>
            </article>
        }
    </section>
}

@code {
    private IReadOnlyList<TypingDictionary>? _dictionaries;

    protected override async Task OnInitializedAsync()
    {
        // Метод жизненного цикла вызывается при первом создании компонента.
        _dictionaries = await Repository.GetAllAsync();
    }

    // switch expression возвращает подпись для каждого значения enum.
    private static string GetKindName(DictionaryKind kind) => kind switch
    {
        DictionaryKind.Words => "Слова",
        DictionaryKind.Phrases => "Фразы",
        DictionaryKind.Texts => "Тексты",
        DictionaryKind.Code => "Код",
        _ => "Словарь"
    };

    private static string GetTextWord(int count)
    {
        // В русском языке окончание зависит от последних цифр:
        // 1 текст, 2 текста, 5 текстов, но 11–14 всегда "текстов".
        int lastTwoDigits = count % 100;
        int lastDigit = count % 10;

        if (lastTwoDigits is >= 11 and <= 14)
        {
            return "текстов";
        }

        return lastDigit switch
        {
            1 => "текст",
            2 or 3 or 4 => "текста",
            _ => "текстов"
        };
    }
}
