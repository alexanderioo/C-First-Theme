@page "/race/{DictionaryId:guid}"
@implements IAsyncDisposable
@inject DictionaryRepository DictionaryRepository
@inject SettingsRepository SettingsRepository

<PageTitle>@(_dictionary is null ? "Заезд" : _dictionary.Name) — Клавиши</PageTitle>

@if (_isLoading)
{
    <section class="empty-state page-card">
        <p>Готовим заезд...</p>
    </section>
}
else if (_dictionary is null)
{
    <section class="empty-state page-card">
        <span class="eyebrow">Словарь не найден</span>
        <h1>Не удалось начать заезд</h1>
        <a class="button button-primary" href="/dictionaries">Выбрать словарь</a>
    </section>
}
else if (_result is not null)
{
    <section class="result-screen">
        <div class="result-heading">
            <span class="eyebrow">Заезд завершён</span>
            <h1>Отличный финиш.</h1>
            <p>@_dictionary.Name · @_targetText.Length символов</p>
        </div>

        <div class="result-grid">
            <article class="primary-result page-card">
                <span>Скорость</span>
                <strong>@_result.CharactersPerMinute</strong>
                <small>знаков в минуту</small>
            </article>
            <article class="page-card">
                <span>Точность</span>
                <strong>@_result.Accuracy.ToString("F1", CultureInfo.CurrentCulture)%</strong>
                <small>@_result.Mistakes @GetMistakeWord(_result.Mistakes)</small>
            </article>
            <article class="page-card">
                <span>Время</span>
                <strong>@FormatTime(TimeSpan.FromSeconds(_result.DurationSeconds))</strong>
                <small>@_result.WordsPerMinute слов/мин</small>
            </article>
        </div>

        <div class="result-actions">
            <button class="button button-primary" type="button" @onclick="StartAnotherRaceAsync">
                Ещё один заезд
            </button>
            <a class="button button-secondary" href="/dictionaries">Другой словарь</a>
            <a class="text-action" href="/statistics">Открыть статистику →</a>
        </div>
    </section>
}
else
{
    <section class="race-shell">
        <div class="race-topline">
            <div>
                <a class="back-link" href="/dictionaries">← Словари</a>
                <span class="dictionary-name">@_dictionary.Name</span>
            </div>
            <div class="race-status">
                <span class="@(_raceStarted ? "live-dot active" : "live-dot")"></span>
                @(_raceStarted ? "Заезд идёт" : "Готов к старту")
            </div>
            <strong class="timer">@FormatTime(_elapsed)</strong>
        </div>

        <div class="typing-card page-card @(_raceStarted ? "is-running" : string.Empty)"
             @onclick="FocusInputAsync">
            @if (!_raceStarted)
            {
                <div class="start-overlay">
                    <span class="eyebrow">Приготовьтесь</span>
                    <h1>Начните печатать<br />после старта</h1>
                    <p>Ошибочный символ станет красным. Исправьте его клавишей Backspace.</p>
                    <button class="button button-primary" type="button" @onclick="StartRaceAsync">
                        Начать заезд
                    </button>
                </div>
            }
            else
            {
                <div class="target-text" aria-label="Текст для набора">
                    @for (int index = 0; index < _targetText.Length; index++)
                    {
                        char character = _targetText[index];
                        <span class="@GetCharacterClass(index)">@character</span>
                    }
                </div>

                <textarea @ref="_typingInput"
                          class="typing-input"
                          value="@_typedText"
                          @oninput="HandleInput"
                          @onpaste:preventDefault
                          aria-label="Поле для набора текста"
                          autocomplete="off"
                          autocapitalize="off"
                          spellcheck="false"></textarea>

                <div class="progress-track">
                    <span style="@($"width: {ProgressPercentage.ToString("F1", CultureInfo.InvariantCulture)}%")"></span>
                </div>

                @if (_typedText.Length == _targetText.Length && _typedText != _targetText)
                {
                    <p class="correction-hint">В тексте осталась ошибка. Исправьте её клавишей Backspace.</p>
                }
                else
                {
                    <p class="focus-hint">Поле активно: просто продолжайте печатать</p>
                }
            }
        </div>

        @if (_settings.ShowLiveMetrics)
        {
            <div class="live-metrics">
                <div>
                    <strong>@LiveCharactersPerMinute</strong>
                    <span>зн/мин</span>
                </div>
                <div>
                    <strong>@LiveAccuracy.ToString("F1", CultureInfo.CurrentCulture)%</strong>
                    <span>точность</span>
                </div>
                <div>
                    <strong>@_mistakes</strong>
                    <span>ошибки</span>
                </div>
                <div>
                    <strong>@_typedText.Length/@_targetText.Length</strong>
                    <span>прогресс</span>
                </div>
            </div>
        }
    </section>
}

@code {
    [Parameter]
    public Guid DictionaryId { get; set; }

    private TypingDictionary? _dictionary;
    private UserSettings _settings = UserSettings.Default;
    private ElementReference _typingInput;
    private PeriodicTimer? _timer;
    private CancellationTokenSource? _timerCancellation;
    private string _targetText = string.Empty;
    private string _typedText = string.Empty;
    private DateTime _startedAt;
    private TimeSpan _elapsed;
    private int _mistakes;
    private int _keyPresses;
    private bool _isLoading = true;
    private bool _raceStarted;
    private RaceResult? _result;

    private double ProgressPercentage => _targetText.Length == 0
        ? 0
        : Math.Min(100, _typedText.Length * 100.0 / _targetText.Length);

    private int LiveCharactersPerMinute
    {
        get
        {
            double minutes = _elapsed.TotalMinutes;
            return minutes <= 0 ? 0 : (int)Math.Round(_typedText.Length / minutes);
        }
    }

    private double LiveAccuracy => _keyPresses == 0
        ? 100
        : Math.Max(0, (_keyPresses - _mistakes) * 100.0 / _keyPresses);

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _dictionary = await DictionaryRepository.GetByIdAsync(DictionaryId);
        _settings = await SettingsRepository.GetAsync();

        if (_dictionary is not null)
        {
            ChooseTargetText();
        }

        _isLoading = false;
    }

    private async Task StartRaceAsync()
    {
        _typedText = string.Empty;
        _mistakes = 0;
        _keyPresses = 0;
        _elapsed = TimeSpan.Zero;
        _result = null;
        _raceStarted = true;
        _startedAt = DateTime.UtcNow;
        StartTimer();

        await InvokeAsync(StateHasChanged);
        await Task.Yield();
        await FocusInputAsync();
    }

    private async Task StartAnotherRaceAsync()
    {
        ChooseTargetText();
        await StartRaceAsync();
    }

    private async Task HandleInput(ChangeEventArgs eventArgs)
    {
        string newValue = eventArgs.Value?.ToString() ?? string.Empty;
        if (newValue.Length > _targetText.Length)
        {
            newValue = newValue[.._targetText.Length];
        }

        int commonPrefixLength = GetCommonPrefixLength(_typedText, newValue);
        for (int index = commonPrefixLength; index < newValue.Length; index++)
        {
            _keyPresses++;
            if (newValue[index] != _targetText[index])
            {
                _mistakes++;
            }
        }

        _typedText = newValue;
        _elapsed = DateTime.UtcNow - _startedAt;

        if (_typedText == _targetText)
        {
            await CompleteRaceAsync();
        }
    }

    private async Task CompleteRaceAsync()
    {
        _elapsed = DateTime.UtcNow - _startedAt;
        StopTimer();
        _raceStarted = false;

        _result = RaceResult.Create(
            _dictionary!,
            _targetText.Length,
            _elapsed,
            _mistakes,
            _keyPresses);

        await InvokeAsync(StateHasChanged);
    }

    private string GetCharacterClass(int index)
    {
        if (index < _typedText.Length)
        {
            return _typedText[index] == _targetText[index] ? "correct" : "incorrect";
        }

        return index == _typedText.Length ? "current" : "pending";
    }

    private async Task FocusInputAsync()
    {
        if (_raceStarted)
        {
            await _typingInput.FocusAsync();
        }
    }

    private void ChooseTargetText()
    {
        if (_dictionary is null || _dictionary.Entries.Count == 0)
        {
            _targetText = string.Empty;
            return;
        }

        List<string> candidates = _dictionary.Entries
            .Where(entry => entry != _targetText)
            .ToList();

        if (candidates.Count == 0)
        {
            candidates = _dictionary.Entries;
        }

        _targetText = candidates[Random.Shared.Next(candidates.Count)];
        _typedText = string.Empty;
        _result = null;
        _raceStarted = false;
        _elapsed = TimeSpan.Zero;
    }

    private void StartTimer()
    {
        StopTimer();
        _timer = new PeriodicTimer(TimeSpan.FromMilliseconds(100));
        _timerCancellation = new CancellationTokenSource();
        _ = UpdateTimerAsync(_timer, _timerCancellation.Token);
    }

    private async Task UpdateTimerAsync(PeriodicTimer timer, CancellationToken cancellationToken)
    {
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                _elapsed = DateTime.UtcNow - _startedAt;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void StopTimer()
    {
        _timerCancellation?.Cancel();
        _timerCancellation?.Dispose();
        _timerCancellation = null;
        _timer?.Dispose();
        _timer = null;
    }

    private static int GetCommonPrefixLength(string first, string second)
    {
        int length = Math.Min(first.Length, second.Length);
        int index = 0;

        while (index < length && first[index] == second[index])
        {
            index++;
        }

        return index;
    }

    private static string FormatTime(TimeSpan time)
    {
        return time.TotalMinutes >= 60
            ? time.ToString(@"hh\:mm\:ss")
            : time.ToString(@"mm\:ss");
    }

    private static string GetMistakeWord(int count)
    {
        int lastTwoDigits = count % 100;
        int lastDigit = count % 10;

        if (lastTwoDigits is >= 11 and <= 14)
        {
            return "ошибок";
        }

        return lastDigit switch
        {
            1 => "ошибка",
            2 or 3 or 4 => "ошибки",
            _ => "ошибок"
        };
    }

    public ValueTask DisposeAsync()
    {
        StopTimer();
        return ValueTask.CompletedTask;
    }
}
